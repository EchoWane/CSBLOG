---

<div class="flex flex-wrap gap-3 sm:gap-4">
  {siteConfig.social.github && (
    <a
      href={siteConfig.social.github}
      target="_blank"
      rel="noopener noreferrer"
      class="text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white transition-colors touch-manipulation"
      aria-label="GitHub"
    >
      <Fragment set:html={socialIcons.github} />
    </a>
  )}
  {siteConfig.social.linkedin && (
    <a
      href={siteConfig.social.linkedin}
      target="_blank"
      rel="noopener noreferrer"
      class="text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white transition-colors touch-manipulation"
      aria-label="LinkedIn"
    >
      <Fragment set:html={socialIcons.linkedin} />
    </a>
  )}
  {siteConfig.social.email && (
    <a
      href={`mailto:${siteConfig.social.email}`}
      class="text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white transition-colors touch-manipulation"
      aria-label="Email"
    >
      <Fragment set:html={socialIcons.email} />
    </a>
  )}
  {siteConfig.social.support && (
    <a
      href={siteConfig.social.support}
      target="_blank"
      rel="noopener noreferrer"
      class="text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300 transition-colors touch-manipulation"
      aria-label="Support Me"
    >
      <Fragment set:html={socialIcons.support} />
    </a>
  )}
  {siteConfig.social.rss && (
    <a
      href="/rss.xml"
      class="text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white transition-colors touch-manipulation"
      aria-label="RSS Feed"
    >
      <Fragment set:html={socialIcons.rss} />
    </a>
  )}
</div>