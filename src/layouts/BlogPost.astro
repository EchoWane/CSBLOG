---
import BaseLayout from './BaseLayout.astro'
import PostDate from '../components/PostDate.astro'
import PostTags from '../components/PostTags.astro'
import ReadingTime from '../components/ReadingTime.astro'
import AuthorCard from '../components/AuthorCard.astro'
import TableOfContents from '../components/TableOfContents.astro'
import BackToTop from '../components/BackToTop.astro'
import type { CollectionEntry } from 'astro:content'
import { calculateReadingTime } from '../utils/readingTime'
import { getHeadings } from '../utils/tableOfContents'

interface Props {
  post: CollectionEntry<'blog'>
}

const { post } = Astro.props
const { title, date, tags, image, authors } = post.data
const { Content, headings: astroHeadings } = await post.render()
const readingTime = calculateReadingTime(post.body)

// Get headings from the markdown content
const headings = astroHeadings || getHeadings(post.body)
---

<BaseLayout title={title}>
  <div class="relative">
    {/* Main Content - Centered with space for fixed TOC on desktop */}
    <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      {image && <img src={image} alt={title} class="w-full h-48 sm:h-64 md:h-80 lg:h-[400px] object-cover rounded-lg sm:rounded-xl shadow-lg mb-6 sm:mb-8" loading="eager" />}

      <header class="mb-8 sm:mb-10 md:mb-12">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-3 sm:mb-4 text-gray-900 dark:text-gray-100 leading-tight">
          {title}
        </h1>
        <div class="flex flex-wrap items-center gap-3 mb-4 sm:mb-6">
          <PostDate date={date} />
          <span class="text-gray-400 dark:text-gray-600">•</span>
          <ReadingTime minutes={readingTime} />
        </div>
        {tags && <PostTags tags={tags} />}
      </header>

      <div
        class="prose prose-sm sm:prose-base md:prose-lg dark:prose-invert
        prose-headings:text-gray-900 dark:prose-headings:text-gray-100
        prose-headings:scroll-mt-20
        prose-p:text-gray-700 dark:prose-p:text-gray-300
        prose-a:text-primary-600 dark:prose-a:text-primary-400
        hover:prose-a:text-primary-500 dark:hover:prose-a:text-primary-300
        prose-strong:text-gray-900 dark:prose-strong:text-gray-100
        prose-code:text-[rgb(36,41,47)] dark:prose-code:text-[rgb(230,237,243)]
        prose-code:bg-[rgb(246,248,250)] dark:prose-code:bg-[rgb(48,54,61)]
        prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
        prose-code:text-xs sm:prose-code:text-sm
        prose-code:before:content-none prose-code:after:content-none
        prose-blockquote:text-gray-700 dark:prose-blockquote:text-gray-300
        prose-span:text-gray-700 dark:prose-span:text-gray-300
        prose-li:text-gray-700 dark:prose-li:text-gray-300
        prose-img:rounded-lg
        max-w-none"
      >
        <Content />
      </div>

      {/* Author Profile Card */}
      <AuthorCard authorIds={authors} />
    </article>

    {/* Fixed TOC - Handles both mobile and desktop */}
    <TableOfContents headings={headings} />

    {/* Back to Top Button */}
    <BackToTop />
  </div>
</BaseLayout>
