---
import type { CollectionEntry } from "astro:content";
import PostDate from "./PostDate.astro";
import PostTags from "./PostTags.astro";
import ReadingTime from "./ReadingTime.astro";
import { Image } from "astro:assets";
import { calculateReadingTime } from "../utils/readingTime";
import { siteConfig } from "../config";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { title, description, date, tags, image } = post.data;
const readingTime = calculateReadingTime(post.body);

// Ensure image dimensions are available to prevent CLS
const imageWidth = 800; // Set appropriate default width
const imageHeight = 400; // Set appropriate default height
---

<article
  class="mb-8 sm:mb-12 p-4 sm:p-6 bg-gray-50 dark:bg-gray-800/60 rounded-xl shadow-md hover:shadow-xl dark:shadow-gray-700/30 dark:hover:shadow-2xl dark:hover:shadow-primary-500/20 border border-gray-700 dark:border-gray-500/50 transition-all duration-200"
>
  {
    image && (
      <a
        href={`${siteConfig.base}/blog/${post.slug}`}
        class="block mb-3 sm:mb-4"
      >
        <Image
          src={image}
          alt={title}
          width={imageWidth}
          height={imageHeight}
          decoding="async"
          loading="eager"
          class="w-full h-40 sm:h-48 md:h-56 object-cover rounded-lg shadow-md hover:shadow-lg transition-shadow"
        />
      </a>
    )
  }
  <header>
    <h2 class="text-lg sm:text-xl md:text-2xl font-bold mb-2">
      <a
        href={`${siteConfig.base}/blog/${post.slug}`}
        class="text-gray-900 dark:text-white hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
      >
        {title}
      </a>
    </h2>
    <div class="flex flex-wrap items-center gap-2 mb-3 sm:mb-4">
      <PostDate date={date} />
      <span class="text-gray-400 dark:text-gray-600">•</span>
      <ReadingTime minutes={readingTime} />
    </div>
  </header>
  <p
    class="text-sm sm:text-base text-gray-800 dark:text-gray-200 mb-3 sm:mb-4 line-clamp-3"
  >
    {description}
  </p>
  {tags && <PostTags tags={tags} />}
</article>
